@model (string Ja, string En)

<div class="text-center">
    <p class="text-xs tracking-[0.4em] text-primary/60 mb-3 uppercase">@Model.En</p>
    <h2 class="text-2xl md:text-3xl font-semibold tracking-widest text-foreground font-serif-jp">
        @Model.Ja
    </h2>
    <div class="flex items-center justify-center gap-3 mt-4">
        <div class="h-px w-12 bg-border"></div>
        <div class="w-1.5 h-1.5 bg-primary/40 rotate-45"></div>
        <div class="h-px w-12 bg-border"></div>
    </div>
</div>
