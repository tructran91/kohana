@model HomeViewModel
@{
    ViewData["Title"] = "ホーム";
    var logoUrl = "https://hercules-cdn.com/file_xP2rW5J5IEDj7LQIcHLg7GIc";
}

<!-- ===== Header (Fixed Nav) ===== -->
<header class="fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur border-b border-border">
    <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <button data-scroll-to="hero" class="flex items-center gap-1 cursor-pointer group">
            <img src="@logoUrl" alt="KOHANA" class="h-10 w-10 object-contain mix-blend-multiply" />
            <span class="text-[11px] text-muted-foreground leading-tight hidden sm:block tracking-wide">
                国際貿易株式会社
            </span>
        </button>

        <!-- Nav Links (desktop) -->
        <nav class="hidden md:flex items-center gap-8">
            @foreach (var item in Model.NavItems)
            {
                <button data-scroll-to="@item.Id"
                        class="text-sm text-foreground/70 hover:text-primary transition-colors cursor-pointer tracking-wide relative group">
                    @item.Label
                    <span class="absolute -bottom-1 left-0 w-0 h-px bg-primary transition-all group-hover:w-full"></span>
                </button>
            }
        </nav>

        <!-- Nav Links (mobile) -->
        <div class="flex md:hidden gap-4">
            @foreach (var item in Model.NavItems)
            {
                <button data-scroll-to="@item.Id"
                        class="text-xs text-foreground/60 hover:text-primary transition-colors cursor-pointer">
                    @item.ShortLabel
                </button>
            }
        </div>
    </div>
</header>

<!-- ===== Hero ===== -->
<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
         style="background: linear-gradient(160deg, oklch(0.94 0.03 145) 0%, oklch(0.975 0.012 145) 50%, oklch(0.92 0.04 155) 100%);">

    <!-- Decorative vertical lines -->
    <div class="absolute left-16 top-0 bottom-0 w-px bg-border hidden lg:block"></div>
    <div class="absolute right-16 top-0 bottom-0 w-px bg-border hidden lg:block"></div>

    <!-- Japanese pattern circles -->
    <div class="absolute top-24 right-24 w-64 h-64 rounded-full border border-primary/10 opacity-60"></div>
    <div class="absolute top-32 right-32 w-48 h-48 rounded-full border border-primary/10 opacity-40"></div>
    <div class="absolute bottom-32 left-20 w-80 h-80 rounded-full border border-primary/8 opacity-50"></div>

    <div class="hero-fade text-center z-10 px-6">
        <!-- Logo -->
        <div class="hero-logo flex justify-center mb-2">
            <img src="@logoUrl" alt="KOHANA"
                 class="w-44 h-44 md:w-56 md:h-56 object-contain mix-blend-multiply" />
        </div>

        <div class="hero-line w-24 h-px bg-primary/30 mx-auto mb-6"></div>

        <p class="hero-text-1 text-lg md:text-2xl font-light text-foreground/70 tracking-widest mb-2 font-serif-jp">
            国際貿易株式会社
        </p>

        <p class="hero-text-2 text-sm text-muted-foreground tracking-widest mt-2">
            日本とアジアの架け橋
        </p>

        <div class="hero-buttons mt-12 flex flex-col sm:flex-row gap-4 justify-center">
            <button data-scroll-to="about"
                    class="px-8 py-3 bg-primary text-primary-foreground text-sm tracking-widest hover:bg-primary/90 transition-colors cursor-pointer">
                会社について
            </button>
            <button data-scroll-to="contact"
                    class="px-8 py-3 border border-primary text-primary text-sm tracking-widest hover:bg-primary/5 transition-colors cursor-pointer">
                お問い合せ
            </button>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div data-scroll-to="about"
         class="scroll-indicator absolute bottom-8 flex flex-col items-center gap-2 cursor-pointer text-muted-foreground">
        <span class="text-xs tracking-widest">SCROLL</span>
        <i data-lucide="chevron-down" class="w-4 h-4"></i>
    </div>
</section>

<!-- ===== About Section ===== -->
<section id="about" class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="fade-up">
            @await Html.PartialAsync("_SectionTitle", ("KOHANAとは？", "ABOUT US"))

            <div class="mt-12 grid md:grid-cols-2 gap-12 items-start">
                <div class="space-y-6">
                    <p class="text-foreground/80 leading-8 tracking-wide">
                        KOHANA国際貿易株式会社は、お客様へ高品質な製品・サービスを提供するだけでなく、お客様と共に考え協力しながら競争と共存共栄の中で成長をしていきます。
                    </p>
                    <p class="text-foreground/80 leading-8 tracking-wide">
                        お客様のニーズに応える高品質な商品を提供し、<strong>日本とアジアの架け橋</strong>となることを目指しています。
                    </p>

                    <div class="border-l-2 border-primary pl-5 space-y-2 mt-6">
                        @foreach (var line in new[]
                        {
                            "日本のサプリメント、化粧品、健康食品、日用品、薬品、衣類品",
                            "ベトナムへ輸出・国内販売",
                            "自社ブランドの開発",
                            "輸出入: 航空便・船便",
                            "国内: 卸売・ネット販売",
                        })
                        {
                            <p class="text-sm text-foreground/70 leading-7 tracking-wide">・@line</p>
                        }
                    </div>
                </div>

                <!-- Decorative logo element -->
                <div class="flex items-center justify-center">
                    <div class="relative w-64 h-64">
                        <div class="absolute inset-0 border border-primary/15 rotate-12"></div>
                        <div class="absolute inset-4 border border-primary/10 rotate-6"></div>
                        <div class="absolute inset-8 border border-primary/8 rotate-3"></div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <img src="@logoUrl" alt="KOHANA" class="w-40 h-40 object-contain mix-blend-multiply" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Divider -->
<div class="max-w-4xl mx-auto px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
</div>

<!-- ===== Business Section ===== -->
<section id="business" class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="fade-up">
            @await Html.PartialAsync("_SectionTitle", ("事業内容", "BUSINESS"))

            <p class="mt-8 text-center text-foreground/70 leading-8 tracking-wide max-w-xl mx-auto">
                KOHANA国際貿易株式会社は、以下の3つの主要事業を展開している国際貿易企業です。
            </p>

            <div class="mt-14 grid md:grid-cols-3 gap-8">
                @for (int i = 0; i < Model.Businesses.Count; i++)
                {
                    var biz = Model.Businesses[i];
                    <div class="fade-up group border border-border hover:border-primary/40 transition-all duration-300 bg-card hover:shadow-sm overflow-hidden"
                         style="transition-delay:@(i * 150)ms">
                        <!-- Image -->
                        <div class="relative h-48 overflow-hidden bg-muted">
                            <img src="@biz.Image" alt="@biz.Title"
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                            <div class="absolute inset-0 bg-primary/10 group-hover:bg-primary/5 transition-colors duration-300"></div>
                            <span class="absolute top-3 right-4 text-4xl font-bold text-white/20 font-serif-jp">
                                @((i + 1).ToString("00"))
                            </span>
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <div class="flex items-center gap-2 text-primary mb-3">
                                <i data-lucide="@biz.Icon" class="w-[18px] h-[18px]"></i>
                                <h3 class="text-base font-semibold tracking-wide font-serif-jp">@biz.Title</h3>
                            </div>
                            <p class="text-sm text-foreground/65 leading-7 tracking-wide">
                                @biz.Description
                            </p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Divider -->
<div class="max-w-4xl mx-auto px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
</div>

<!-- ===== Company Section ===== -->
<section id="company" class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="fade-up">
            @await Html.PartialAsync("_SectionTitle", ("会社概要", "COMPANY"))

            <div class="mt-12 flex items-start gap-4">
                <i data-lucide="building-2" class="w-5 h-5 text-primary mt-1 shrink-0"></i>
                <p class="text-sm text-foreground/70 leading-7 tracking-wide">
                    KOHANA国際貿易株式会社は、以下の3つの主要事業を展開している国際貿易企業です。
                </p>
            </div>

            <div class="mt-10 border border-border">
                @foreach (var info in Model.CompanyInfo)
                {
                    <div class="fade-left flex border-b border-border last:border-b-0">
                        <div class="w-36 md:w-44 shrink-0 bg-muted px-5 py-4 text-sm font-medium tracking-wide text-foreground/80">
                            @info.Label
                        </div>
                        <div class="px-5 py-4 text-sm text-foreground/70 leading-6 tracking-wide">
                            @info.Value
                        </div>
                    </div>
                }
            </div>

            <!-- Map -->
            <div class="fade-up mt-12">
                <div class="flex items-center gap-2 mb-4">
                    <i data-lucide="map-pin" class="w-[14px] h-[14px] text-primary"></i>
                    <span class="text-xs tracking-widest text-foreground/60 uppercase">
                        本社所在地 — 千葉県船橋市大穴南1丁目40番6号
                    </span>
                </div>
                <div class="border border-border overflow-hidden" style="height:340px">
                    <div id="company-map"
                         data-lat="@Model.MapLat.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-lng="@Model.MapLng.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-zoom="@Model.MapZoom"
                         style="height:100%;width:100%"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Divider -->
<div class="max-w-4xl mx-auto px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
</div>

<!-- ===== Contact Section ===== -->
<section id="contact" class="py-28 px-6">
    <div class="max-w-2xl mx-auto">
        <div class="fade-up">
            @await Html.PartialAsync("_SectionTitle", ("お問い合せ", "CONTACT"))

            <div class="mt-8 flex flex-wrap gap-6 justify-center mb-12">
                <div class="flex items-center gap-2 text-sm text-foreground/60">
                    <i data-lucide="phone" class="w-[14px] h-[14px] text-primary"></i>
                    <span>047-466-8658</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-foreground/60">
                    <i data-lucide="map-pin" class="w-[14px] h-[14px] text-primary"></i>
                    <span>千葉県船橋市大穴南1丁目40番6号</span>
                </div>
            </div>

            @if (TempData["ContactSuccess"] != null)
            {
                <p class="text-center text-sm text-primary mb-6">メッセージを送信しました。</p>
            }

            <form id="contact-form" class="space-y-5" method="post" action="@Url.Action("Contact", "Home")">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-xs tracking-widest text-foreground/60 mb-2 uppercase">
                        お名前 <span class="text-primary">*</span>
                    </label>
                    <input required type="text" name="name" placeholder="山田 太郎"
                           class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div>
                    <label class="block text-xs tracking-widest text-foreground/60 mb-2 uppercase">
                        メールアドレス <span class="text-primary">*</span>
                    </label>
                    <input required type="email" name="email" placeholder="example@email.com"
                           class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div>
                    <label class="block text-xs tracking-widest text-foreground/60 mb-2 uppercase">
                        メッセージ本文
                    </label>
                    <textarea rows="5" name="message" placeholder="お問い合せ内容をご記入ください"
                              class="w-full border border-border bg-card px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors resize-none"></textarea>
                </div>
                <div class="flex justify-center pt-4">
                    <button type="submit"
                            class="px-12 py-3 bg-primary text-primary-foreground text-sm tracking-widest hover:bg-primary/90 transition-colors cursor-pointer">
                        送信
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- ===== Footer ===== -->
<footer class="border-t border-border py-10 px-6 bg-muted/30">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
            <img src="@logoUrl" alt="KOHANA" class="h-9 w-9 object-contain mix-blend-multiply" />
            <span class="text-xs text-muted-foreground tracking-wide">国際貿易株式会社</span>
        </div>
        <div class="flex gap-6">
            @foreach (var item in Model.NavItems)
            {
                <button data-scroll-to="@item.Id"
                        class="text-xs text-muted-foreground hover:text-primary transition-colors cursor-pointer tracking-wide">
                    @item.Label
                </button>
            }
        </div>
        <p class="text-xs text-muted-foreground">
            &copy; @DateTime.Now.Year KOHANA国際貿易株式会社
        </p>
    </div>
</footer>
