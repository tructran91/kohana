@{
    ViewData["Title"] = "トップ";
    Layout = "_Layout";
}

<!-- ===== HEADER ===== -->
<header class="site-header">
    <div class="container header-top">
        <a href="/" class="logo">
            <img src="~/images/logo-s.png" alt="VJC国際貿易株式会社" />
        </a>
        <nav class="main-nav">
            <ul>
                <li><a href="/">トップ</a></li>
                <li><a href="#jigyou">貿易事業</a></li>
                <li><a href="#shoukai">会社概要</a></li>
                <li><a href="#lienhe">お問い合せ</a></li>
            </ul>
        </nav>
    </div>
    <div class="header-info">
        <div class="container">
            電話番号：047-466-8658｜ 営業時間：平日 AM10:00〜PM7:00｜ 住所：千葉県船橋市大穴南1丁目40番6号
        </div>
    </div>
</header>

<!-- ===== HERO ===== -->
<section class="hero">
    <div class="hero-decor">
        <img src="~/images/hero-line-shape.png" class="decor line-shape" alt="" />
        <img src="~/images/hero-ellipse.png" class="decor ellipse" alt="" />
        <img src="~/images/stars-2.png" class="decor stars-2-a" alt="" />
        <img src="~/images/stars-1.png" class="decor stars-1" alt="" />
        <img src="~/images/stars-2.png" class="decor stars-2-b" alt="" />
        <img src="~/images/start.png" class="decor start" alt="" />
    </div>
    <div class="container hero-content">
        <h1>VJCとは？</h1>
        <p>
            VJC国際貿易株式会社は、お客様へ高品質な製品・サービスを提供するだけでなく、
            お客様と共に考え協力しながら競争と共存共栄の中で成長をしていきます。
        </p>
        <a href="#jigyou" class="btn btn-primary">詳細</a>
    </div>
</section>

<!-- ===== 貿易事業 (BUSINESS SECTIONS) ===== -->
<section id="jigyou" class="business-section">
    <div class="container">
        <div class="business-images">
            <img src="~/images/5.png" alt="VJC事業1" />
            <img src="~/images/6.png" alt="VJC事業2" />
        </div>

        <p class="business-intro-bold">
            VJC国際貿易株式会社は、以下の3つの主要事業を展開している国際貿易企業です。
        </p>
        <p class="business-intro">
            お客様のニーズに応える高品質な商品を提供し、日本とアジアの架け橋となることを目指しています。
        </p>

        <div class="business-cards">
            <div class="business-card">
                <img src="~/img/2.png" alt="輸出入事業" />
                <p>
                    日本国内の健康・医療関連商品、サプリメント、日用品などをベトナムへ輸出するとともに、
                    ベトナムおよび中国からの多様な商品を日本へ輸入しております。
                </p>
            </div>
            <div class="business-card">
                <img src="~/img/3.png" alt="国内販売事業" />
                <p>
                    輸入商品だけでなく、日本国内の高品質な製品も取り扱い、
                    全国の小売市場およびオンラインを通じて販売しています。
                </p>
            </div>
            <div class="business-card">
                <img src="~/img/kinh.png" alt="自社ブランド事業" />
                <p>
                    当社が登録したブランドに基づき、オリジナル製品を企画・製造し、国内外に向けて販売しています。
                </p>
            </div>
        </div>

        <ul class="business-list">
            <li>日本のサプリメント、化粧品、健康食品、日用品、薬品、衣類品を中心として</li>
            <li>ベトナムへ輸出、国内販売。</li>
            <li>その他に自社ブランドの開発を行っています。</li>
            <li>取引形態</li>
            <li>ベトナムへ輸出入 航空便、船便</li>
            <li>日本国内売り: 他社へ卸売、ネット販売</li>
        </ul>
    </div>
</section>

<!-- ===== 会社概要 (COMPANY INFO) ===== -->
